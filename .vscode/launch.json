{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "cwd": "${workspaceFolder}",
            "executable": "build/GD32F4xx_Template.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "external",
            "gdbTarget": "127.0.0.1:50000",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            },
            "postLaunchCommands": [
                "monitor reset halt", // 通知远程 Server 复位并挂起 CPU
                "load", // 核心指令：将 executable 指定的文件烧录到 Flash
                "monitor reset halt" // 再次复位，确保程序从头开始（可选）
            ]
        },
    ]
}
